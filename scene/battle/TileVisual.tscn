[gd_scene format=3 uid="uid://5db1yomg1t4d"]

[sub_resource type="GDScript" id="GDScript_ikp3i"]
script/source = "class_name TileVisual
extends Node2D

@onready var background: ColorRect = $Background
@onready var label: Label = $Label

var tile_data: BattleTileData

func setup(p_tile_data: BattleTileData, tile_size: int) -> void:
	tile_data = p_tile_data
	
	background.size = Vector2(tile_size, tile_size)
	background.position = Vector2(-tile_size / 2.0, -tile_size / 2.0)
	
	label.text = str(tile_data.height)
	label.position = Vector2(-8, -12)
	
	_update_color()

func _update_color() -> void:
	if tile_data == null:
		return
	
	match tile_data.height:
		0:
			background.color = Color(0.25, 0.55, 0.25, 1.0)
		1:
			background.color = Color(0.35, 0.65, 0.35, 1.0)
		2:
			background.color = Color(0.45, 0.55, 0.30, 1.0)
		3:
			background.color = Color(0.55, 0.45, 0.25, 1.0)
		_:
			background.color = Color(0.65, 0.65, 0.65, 1.0)
"

